generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  avatar    String?
  bio       String?
  location  String?
  website   String?
  instagram String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trips     Trip[]
  stories   Story[]
  comments  Comment[]
  likes     Like[]
  followers Follow[]  @relation("following")
  following Follow[]  @relation("followers")

  @@map("users")
}

model Trip {
  id          String     @id @default(cuid())
  title       String
  description String?
  userId      String
  startDate   DateTime
  endDate     DateTime
  totalBudget Float
  status      TripStatus @default(PLANNED)
  coverImage  String?
  isPublic    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  destinations Destination[]
  expenses     Expense[]
  story        Story?

  @@map("trips")
}

enum TripStatus {
  PLANNED
  ACTIVE
  COMPLETED
}

model Destination {
  id           String    @id @default(cuid())
  tripId       String
  locationName String
  country      String?
  latitude     Float
  longitude    Float
  order        Int
  arrivalDate  DateTime?
  departDate   DateTime?
  nights       Int?
  notes        String?
  createdAt    DateTime  @default(now())

  trip       Trip       @relation(fields: [tripId], references: [id], onDelete: Cascade)
  activities Activity[]

  @@map("destinations")
}

model Activity {
  id            String  @id @default(cuid())
  destinationId String
  name          String
  type          String?
  time          String?
  cost          Float?
  notes         String?

  destination Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  @@map("activities")
}

model Expense {
  id          String          @id @default(cuid())
  tripId      String
  category    ExpenseCategory
  amount      Float
  currency    String          @default("USD")
  description String
  date        DateTime
  receipt     String?
  createdAt   DateTime        @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@map("expenses")
}

enum ExpenseCategory {
  ACCOMMODATION
  TRANSPORT
  FOOD
  ACTIVITIES
  SHOPPING
  HEALTH
  COMMUNICATIONS
  OTHER
}

model Story {
  id        String   @id @default(cuid())
  userId    String
  tripId    String?  @unique
  title     String
  content   String   @db.Text
  excerpt   String?
  location  String
  images    String[]
  tags      String[]
  published Boolean  @default(false)
  views     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip     Trip?     @relation(fields: [tripId], references: [id])
  comments Comment[]
  likes    Like[]

  @@map("stories")
}

model Comment {
  id        String   @id @default(cuid())
  storyId   String
  userId    String
  content   String
  createdAt DateTime @default(now())

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model Like {
  id        String   @id @default(cuid())
  storyId   String
  userId    String
  createdAt DateTime @default(now())

  @@unique([storyId, userId])
  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("likes")
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  follower  User @relation("followers", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@map("follows")
}
